generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StoryType {
  story
  dialogue
  journal
}

enum StoryLevel {
  beginner
  elementary
  intermediate
}

enum StoryVisibility {
  public_seeded
  private_user
  public_user
}

enum LessonLength {
  short
  medium
  long
}

model User {
  id            String         @id
  name          String
  email         String         @unique
  emailVerified Boolean        @default(false)
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
  accounts      Account[]
  stories       Story[]
  storyReads    StoryRead[]
  vocabularyReads VocabularyRead[]
  aiUsageEvents AiUsageEvent[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Story {
  id                 String          @id @default(cuid())
  slug               String          @unique
  title              String
  titleTranslation   String
  summary            String
  excerpt            String
  hanziText          String
  pinyinText         String
  englishTranslation String
  sections           Json
  type               StoryType
  hskLevel           String
  level              StoryLevel
  visibility         StoryVisibility @default(private_user)
  isSeeded           Boolean         @default(false)
  authorUserId             String?
  author                   User?           @relation(fields: [authorUserId], references: [id], onDelete: SetNull)
  seriesGroupSlug          String?
  seriesEpisode            Int?
  seriesTitle              String?
  seriesTitleTranslation   String?
  seriesSummary            String?
  lessonLength             LessonLength?
  reads                    StoryRead[]
  views                    StoryView?
  aiUsageEvents            AiUsageEvent[]
  hanziTerms               StoryHanziTerm[]
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@index([visibility, createdAt(sort: Desc)])
  @@index([authorUserId, createdAt(sort: Desc)])
  @@index([seriesGroupSlug, seriesEpisode])
  @@map("story")
}

model AiUsageEvent {
  id                String   @id @default(cuid())
  userId            String
  storyId           String?
  model             String
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  /// OpenRouter-reported cost (credits), when present
  costCredits       Decimal? @db.Decimal(18, 8)
  providerRequestId String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story             Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([storyId])
  @@map("ai_usage_event")
}

/// Reverse index: which Han characters / segmented words appear in each story (and thus in series episodes).
model StoryHanziTerm {
  id      String @id @default(cuid())
  storyId String
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  /// Single CJK codepoint or a multi-character segmented word from story title + body.
  term    String @db.VarChar(128)

  @@unique([storyId, term])
  @@index([term])
  @@map("story_hanzi_term")
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String   @unique
  viewCount Int      @default(0)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@map("story_view")
}

model StoryRead {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  readAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId, readAt(sort: Desc)])
  @@index([storyId])
  @@map("story_read")
}

model VocabularyRead {
  id         String   @id @default(cuid())
  userId     String
  hanzi      String
  readCount  Int      @default(0)
  lastReadAt DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hanzi])
  @@index([userId, lastReadAt(sort: Desc)])
  @@map("vocabulary_read")
}
