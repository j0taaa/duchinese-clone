# Copy to .env and fill in values (see your hosting provider / Prisma for DATABASE_URL).

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
BETTER_AUTH_SECRET="generate-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenRouter — server-only; used for AI story generation (shared key for all users)
OPENROUTER_API_KEY="sk-or-v1-..."
# Optional overrides:
# OPENROUTER_CHAT_URL="https://openrouter.ai/api/v1/chat/completions"
# OPENROUTER_MODEL="google/gemini-3.1-flash-lite-preview"
# OPENROUTER_IDEA_MODEL="..."  # optional; short JSON topic-idea calls (defaults to OPENROUTER_MODEL)
# OPENROUTER_HTTP_REFERER="https://your-app.example"
# OPENROUTER_APP_TITLE="HanziLane"
